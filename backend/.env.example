# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3007
NODE_ENV=production

# ─── Security (REQUIRED in production) ────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_secret

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins (leave blank if using APP_DOMAIN)
ALLOWED_ORIGINS=https://yourdomain.com

# Root domain for wildcard subdomain support (e.g. "yourdomain.com")
# Allows any https://<slug>.yourdomain.com origin automatically
APP_DOMAIN=yourdomain.com

# ─── Default org admin (REQUIRED in production — created once on first boot) ──
DEFAULT_ADMIN_EMAIL=admin@yourdaycare.com
DEFAULT_ADMIN_PASSWORD=ChangeMe1234!

# ─── Platform superadmin (REQUIRED in production) ─────────────────────────────
SUPERADMIN_EMAIL=you@youremail.com
SUPERADMIN_PASSWORD=ChangeMe1234!

# ─── Stripe (optional — for billing/subscription management) ──────────────────
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
